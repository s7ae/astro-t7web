  <script is:inline>
    function openReadmeModal() {
      const modal = document.getElementById('readmeModal');
      const container = modal.querySelector('.readme-container');
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      
      requestAnimationFrame(() => {
        container.classList.add('animate');
      });
    }

    function closeReadmeModal() {
      const modal = document.getElementById('readmeModal');
      const container = modal.querySelector('.readme-container');
      
      container.classList.remove('animate');
      container.classList.add('closing');
      
      setTimeout(() => {
        modal.classList.remove('active');
        modal.classList.remove('closing');
        document.body.style.overflow = '';
        document.getElementById('agreeCheckbox').checked = false;
        document.getElementById('downloadBtn').style.pointerEvents = 'none';
        document.getElementById('downloadBtn').style.opacity = '0.5';
      }, 400);
    }

    function handleDownload(event) {
      const checkbox = document.getElementById('agreeCheckbox');
      const downloadBtn = document.getElementById('downloadBtn');
      
      if (!checkbox.checked) {
        event.preventDefault();
        downloadBtn.style.animation = 'shake 0.5s ease';
        setTimeout(() => {
          downloadBtn.style.animation = '';
        }, 500);
        return;
      }
    }

    
    document.addEventListener('DOMContentLoaded', () => {
      const checkbox = document.getElementById('agreeCheckbox');
      const downloadBtn = document.getElementById('downloadBtn');
      
      if (checkbox && downloadBtn) {
        checkbox.addEventListener('change', () => {
          if (checkbox.checked) {
            downloadBtn.style.pointerEvents = 'auto';
            downloadBtn.style.opacity = '1';
            downloadBtn.style.transform = 'scale(1.05)';
            setTimeout(() => {
              downloadBtn.style.transform = 'scale(1)';
            }, 200);
          } else {
            downloadBtn.style.pointerEvents = 'none';
            downloadBtn.style.opacity = '0.5';
          }
        });
        
        
        downloadBtn.style.pointerEvents = 'none';
        downloadBtn.style.opacity = '0.5';
      }
    });

    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeReadmeModal();
      }
    });
  </script>
</BaseLayout>

<style>
  
  .readme-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .readme-modal.active {
    opacity: 1;
    visibility: visible;
  }

  .readme-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .readme-container {
    position: relative;
    width: 90%;
    max-width: 680px;
    max-height: 85vh;
    background: linear-gradient(145deg, rgba(20, 20, 28, 0.98), rgba(13, 13, 18, 0.98));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    box-shadow: 
      0 25px 80px rgba(0, 0, 0, 0.6),
      0 0 60px rgba(232, 137, 74, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    overflow: hidden;
    transform: scale(0.8) translateY(40px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), 
                opacity 0.4s ease,
                border-radius 0.5s ease,
                box-shadow 0.5s ease;
  }

  .readme-container.animate {
    transform: scale(1) translateY(0);
    opacity: 1;
    border-radius: 24px;
  }

  .readme-container.closing {
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.3s ease,
                border-radius 0.35s ease;
  }

  .readme-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px 28px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .readme-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, rgba(232, 137, 74, 0.2), rgba(245, 164, 98, 0.1));
    border: 1px solid rgba(232, 137, 74, 0.3);
    border-radius: 12px;
    color: #e8894a;
  }

  .readme-title {
    flex: 1;
    font-size: 22px;
    font-weight: 600;
    color: #f5f5f7;
    margin: 0;
  }

  .readme-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .readme-close:hover {
    background: rgba(255, 107, 107, 0.15);
    border-color: rgba(255, 107, 107, 0.3);
    color: #ff6b6b;
    transform: rotate(90deg);
  }

  .readme-content {
    padding: 24px 28px;
    max-height: calc(85vh - 200px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(232, 137, 74, 0.3) transparent;
  }

  .readme-content::-webkit-scrollbar {
    width: 6px;
  }

  .readme-content::-webkit-scrollbar-track {
    background: transparent;
  }

  .readme-content::-webkit-scrollbar-thumb {
    background: rgba(232, 137, 74, 0.3);
    border-radius: 3px;
  }

  .readme-section {
    margin-bottom: 24px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    transition: all 0.3s ease;
  }

  .readme-section:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateX(4px);
  }

  .readme-section h3 {
    font-size: 16px;
    font-weight: 600;
    color: #f5a462;
    margin: 0 0 14px 0;
  }

  .readme-placeholder {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.8;
    white-space: pre-line;
    font-family: 'SF Mono', 'Fira Code', monospace;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    border-left: 3px solid rgba(232, 137, 74, 0.3);
  }

  .readme-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 20px 28px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    flex-wrap: wrap;
  }

  .readme-checkbox {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    user-select: none;
  }

  .readme-checkbox input {
    display: none;
  }

  .checkbox-custom {
    width: 22px;
    height: 22px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    position: relative;
  }

  .checkbox-custom::after {
    content: 'вЬ?;
    font-size: 14px;
    font-weight: bold;
    color: white;
    opacity: 0;
    transform: scale(0);
    transition: all 0.2s ease;
  }

  .readme-checkbox input:checked + .checkbox-custom {
    background: linear-gradient(135deg, #e8894a, #f5a462);
    border-color: #e8894a;
    box-shadow: 0 0 20px rgba(232, 137, 74, 0.4);
  }

  .readme-checkbox input:checked + .checkbox-custom::after {
    opacity: 1;
    transform: scale(1);
  }

  .checkbox-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #e8894a, #f5a462);
    border: none;
    border-radius: 12px;
    color: white;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
      0 8px 24px rgba(232, 137, 74, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .btn-download:hover {
    transform: translateY(-2px);
    box-shadow: 
      0 12px 32px rgba(232, 137, 74, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-8px); }
    40% { transform: translateX(8px); }
    60% { transform: translateX(-6px); }
    80% { transform: translateX(6px); }
  }

  
  @media (max-width: 640px) {
    .readme-container {
      width: 95%;
      max-height: 90vh;
      border-radius: 20px;
    }

    .readme-header {
      padding: 18px 20px;
    }

    .readme-title {
      font-size: 18px;
    }

    .readme-content {
      padding: 18px 20px;
      max-height: calc(90vh - 180px);
    }

    .readme-footer {
      flex-direction: column;
      gap: 16px;
      padding: 18px 20px;
    }

    .btn-download {
      width: 100%;
      justify-content: center;
    }
  }
</style>
